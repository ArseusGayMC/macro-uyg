<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wireless Debugging → Eşleştirme seçeneğinden IP:Port ve kodu görün"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="16dp" />

    <android.widget.EditText
        android:id="@+id/etPairIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="IP Adresi (örn: 192.168.1.5)"
        android:inputType="text"
        android:layout_marginBottom="8dp" />

    <android.widget.EditText
        android:id="@+id/etPairPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Eşleştirme Portu"
        android:inputType="number"
        android:layout_marginBottom="8dp" />

    <android.widget.EditText
        android:id="@+id/etPairCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="6 Haneli Eşleştirme Kodu"
        android:inputType="number"
        android:maxLength="6" />

</LinearLayout>
